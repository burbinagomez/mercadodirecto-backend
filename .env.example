# Database
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/mercadodirecto
# Zero-dependency local dev: DATABASE_URL=sqlite:///./mercadodirecto.db

# Auth
JWT_SECRET=change-me-in-prod
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS (comma separated origins)
CORS_ORIGINS=http://localhost:3000

# VelaFi payments (https://docs.velafi.com) — sandbox by default
VELAFI_BASE_URL=https://api-test.velafi.com
VELAFI_API_KEY=
VELAFI_WEBHOOK_PUBLIC_KEY=
APP_BASE_URL=http://localhost:8000
